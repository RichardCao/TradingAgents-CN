# Copy this file to a local path, fill in the required values, then run:
#   ./scripts/startup/start_local_stack.sh --env /path/to/local_stack.env

# Required model settings
TA_MODEL_PROVIDER=openai
TA_MODEL_NAME=gpt-5.4
TA_MODEL_BASE_URL=https://api.openai.com/v1
TA_MODEL_API_KEY=

# Optional provider display name shown in the database/UI
TA_PROVIDER_DISPLAY_NAME=OpenAI Compatible Local

# Optional app settings
TA_DEFAULT_DATA_SOURCE=AKShare
TA_ENABLE_MINIMAL_STARTUP=true
TA_BACKEND_PORT=8000
TA_FRONTEND_PORT=3000

# Optional realtime fallback guardrails for A-share quotes
# Keep enabled if you want sina_finance / hq.sinajs.cn as the final small-batch fallback.
TRADINGAGENTS_ENABLE_SINA_FINANCE_FALLBACK=true
TRADINGAGENTS_SINA_FINANCE_FALLBACK_MAX_SYMBOLS=20

# Optional admin account seeded into MongoDB
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_local_admin_password
ADMIN_EMAIL=admin@tradingagents.local

# Optional MongoDB/Redis settings
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_DATABASE=tradingagents
MONGODB_AUTH_SOURCE=admin

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
